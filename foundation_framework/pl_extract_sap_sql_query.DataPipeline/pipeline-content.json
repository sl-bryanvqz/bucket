                    "value": {
                      "value": "@pipeline().libraryVariables.vl_guids_bronze_lakehouse_id",
                      "type": "Expression"
                    },
                    "type": "string"
                  },
                  "target_file_path": {
                    "value": {
                      "value": "@concat(\n    'incoming/',\n    json(string(pipeline().parameters.target_settings)).target_file_path,\n    '/',\n    formatDateTime(pipeline().TriggerTime, 'yyyy-MM-dd'),\n    '/lineage_id=',\n    pipeline().parameters.lineage_id\n\n)",
                      "type": "Expression"
                    },
                    "type": "string"
                  },
                  "target_file_name": {
                    "value": {
                      "value": "@concat(json(string(pipeline().parameters.target_settings)).target_file_name,'.parquet')",
                      "type": "Expression"
                    },
                    "type": "string"
                  },
                  "incremental_field": {
                    "value": {
                      "value": "@json(string(pipeline().parameters.source_settings)).values.incremental_column",
                      "type": "Expression"
                    },
                    "type": "string"
                  }
                }
              },
              "policy": {
                "timeout": "0.00:10:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureInput": false,
                "secureOutput": false
              },
              "name": "get max watermark",
              "description": "Uses the notebook to dynamically determine the watermark value of the new ingestion",
              "dependsOn": []
