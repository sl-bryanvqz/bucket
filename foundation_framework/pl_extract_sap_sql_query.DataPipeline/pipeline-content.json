            {
              "type": "TridentNotebook",
              "typeProperties": {
                "notebookId": "6ff31b98-0f4f-8cb2-47ed-cd298e3c2a60",
                "workspaceId": "00000000-0000-0000-0000-000000000000",
                "parameters": {
                  "task_id": {
                    "value": {
                      "value": "@pipeline().parameters.task_id",
                      "type": "Expression"
                    },
                    "type": "string"
                  },
                  "bronze_workspace_id": {
                    "value": {
                      "value": "@pipeline().libraryVariables.vl_guids_bronze_workspace_id",
                      "type": "Expression"
                    },
                    "type": "string"
                  },
