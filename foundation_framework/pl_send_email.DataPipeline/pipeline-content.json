{
  "properties": {
    "activities": [
      {
        "name": "Send email",
        "description": "Sends a notification via Outlook Email to the recipient, notifying them of the status of their pipeline",
        "type": "Office365Outlook",
        "dependsOn": [],
        "typeProperties": {
          "inputs": {
            "method": "post",
            "path": "/v2/Mail",
            "body": {
              "To": "@pipeline().parameters.email_address",
              "Subject": "@pipeline().parameters.email_subject",
              "Body": "<p>@{pipeline().parameters.email_body}<br>\n<br>\n<strong>Execution URL: </strong>@{pipeline().parameters.execution_url}</p>",
              "Sensitivity": "",
              "Importance": "Normal"
            }
          }
        }
      }
    ],
    "parameters": {
      "email_address": {
        "type": "string"
      },
      "email_subject": {
        "type": "string"
      },
      "email_body": {
        "type": "string"
      },
      "execution_url": {
        "type": "string"
      }
    },
    "logicAppsConnectionPayload": {
      "id": "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/your-connections-resource-group/providers/Microsoft.Web/connections/your-office365-connection",
      "properties": {
        "api": {
          "name": "office365",
          "id": "/subscriptions/00000000-0000-0000-0000-000000000000/providers/Microsoft.Web/locations/your-region/managedApis/office365"
        }
      }
    }
  }
}
