{
  "properties": {
    "activities": [
      {
        "name": "Extract SQL",
        "description": "Copies data from SQL server to bronze lakehouse",
        "type": "Copy",
        "dependsOn": [
          {
            "activity": "Set sql_query",
            "dependencyConditions": [
              "Succeeded"
            ]
          },
          {
            "activity": "Copy row count for audit",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "0.12:00:00",
          "retry": 2,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "typeProperties": {
          "source": {
            "type": "FabricSqlDatabaseSource",
            "sqlReaderQuery": {
              "value": "@variables('sql_query')",
              "type": "Expression"
            },
            "queryTimeout": "02:00:00",
            "partitionOption": "None",
            "datasetSettings": {
              "annotations": [],
              "connectionSettings": {
                "name": "a8093e9f_304b_4e5f_8b54_57823bc03605",
                "properties": {
                  "annotations": [],
                  "type": "FabricSqlDatabase",
                  "typeProperties": {
                    "workspaceId": "@pipeline().DataFactory",
                    "artifactId": "@json(string(pipeline().parameters.source_settings)).sql_db_id"
                  },
                  "externalReferences": {
                    "connection": "@json(string(pipeline().parameters.source_connection_settings)).fabric_connection_id"
                  }
                }
              },
              "type": "FabricSqlDatabaseTable",
              "schema": [],
              "typeProperties": {}
            }
          },
          "sink": {
            "type": "ParquetSink",
            "storeSettings": {
              "type": "AzureBlobStorageWriteSettings"
            },
            "formatSettings": {
              "type": "ParquetWriteSettings",
              "enableVertiParquet": true
            },
            "datasetSettings": {
              "annotations": [],
              "linkedService": {
                "name": "e9541c62_37b0_4678_8473_a9ac25b91fa6",
                "properties": {
                  "annotations": [],
                  "type": "Lakehouse",
                  "typeProperties": {
                    "workspaceId": "@pipeline().libraryVariables.vl_guids_bronze_workspace_id",
                    "artifactId": "@pipeline().libraryVariables.vl_guids_bronze_lakehouse_id",
                    "rootFolder": "Files"
                  }
                }
              },
              "type": "Parquet",
              "typeProperties": {
                "location": {
                  "type": "LakehouseLocation",
                  "folderPath": {
                    "value": "@concat(\n    'incoming/',\n    json(string(pipeline().parameters.target_settings)).target_file_path,\n    '/',\n    formatDateTime(pipeline().TriggerTime, 'yyyy-MM-dd'),\n    '/lineage_id=',\n    pipeline().parameters.lineage_id\n\n)",
                    "type": "Expression"
                  }
                },
                "compressionCodec": "snappy"
              },
              "schema": []
            }
          },
          "enableStaging": false,
          "translator": {
            "type": "TabularTranslator",
            "typeConversion": true,
            "typeConversionSettings": {
              "allowDataTruncation": true,
              "treatBooleanAsNumber": false
            }
          }
        }
